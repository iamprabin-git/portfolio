# Copy to .env.local and set strong values before running locally or in production.

# Initial admin login password. After you set a password in Admin → Settings, the saved hash is used instead (env value ignored).
ADMIN_PASSWORD=change-me-in-production

# Random secret for signing admin sessions (min 16 characters)
AUTH_SECRET=replace-with-a-long-random-string

# Optional: MongoDB connection (Atlas or local). When set, portfolio data is stored in
# database MONGODB_DB (default: portfolio), collection MONGODB_COLLECTION (default: site),
# document _id "main". When unset, data/portfolio.json is used (same shape).
# Paste your Atlas URI here; replace <db_password> with that user's password (URL-encode @ # % etc.).
# Put the DB name before ? so it matches MONGODB_DB (default portfolio):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority&appName=YOUR_APP
# MONGODB_DB=portfolio
# MONGODB_COLLECTION=site

# Optional (production uploads): Vercel Blob — added automatically when you create/link a Blob
# store to this project in Vercel → Storage. Required for Admin “Upload image” on Vercel
# (the server filesystem is read-only and /uploads/… URLs do not persist).
# BLOB_READ_WRITE_TOKEN=…
